{
  "name": "bitwise-flag",
  "version": "2.0.0",
  "type": "module",
  "sideEffects": false,
  "description": "Type-safe, immutable bitwise flags for TypeScript — with named flags, human-readable aliases, and tree-shakeable operators. ",
  "keywords": [
    "bitwise",
    "bitmask",
    "flags",
    "bitfield",
    "typescript",
    "bitwise-flags",
    "permissions"
  ],
  "homepage": "https://thatsembarrassing.github.io/bitwise-flag",
  "files": [
    "./dist/*.js",
    "./dist/*.d.ts",
    "./README.md",
    "./LICENSE.md",
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./operators": {
      "require": {
        "types": "./dist/operators/index.d.cts",
        "default": "./dist/operators/index.cjs"
      },
      "import": {
        "types": "./dist/operators/index.d.ts",
        "default": "./dist/operators/index.js"
      }
    },
    "./operators/basic": {
      "require": {
        "types": "./dist/operators/basic/index.d.cts",
        "default": "./dist/operators/basic/index.cjs"
      },
      "import": {
        "types": "./dist/operators/basic/index.d.ts",
        "default": "./dist/operators/basic/index.js"
      }
    },
    "./operators/set": {
      "require": {
        "types": "./dist/operators/set/index.d.cts",
        "default": "./dist/operators/set/index.cjs"
      },
      "import": {
        "types": "./dist/operators/set/index.d.ts",
        "default": "./dist/operators/set/index.js"
      }
    },
    "./operators/utils": {
      "require": {
        "types": "./dist/operators/utils/index.d.cts",
        "default": "./dist/operators/utils/index.cjs"
      },
      "import": {
        "types": "./dist/operators/utils/index.d.ts",
        "default": "./dist/operators/utils/index.js"
      }
    },
    "./operators/errors": {
      "require": {
        "types": "./dist/operators/errors/index.d.cts",
        "default": "./dist/operators/errors/index.cjs"
      },
      "import": {
        "types": "./dist/operators/errors/index.d.ts",
        "default": "./dist/operators/errors/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThatsEmbarrassing/bitwise-flag.git"
  },
  "author": "Ember",
  "scripts": {
    "build": "bunup",
    "tests": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "publint": "publint --pack npm",
    "attw": "attw --pack .",
    "docs": "typedoc",
    "docs:serve": "typedoc --watch",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bunup && changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.0",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/bun": "^1.3.1",
    "bunup": "^0.15.13",
    "eslint": "^9.39.0",
    "lefthook": "^2.1.9",
    "publint": "^0.3.21",
    "typedoc": "^0.28.14",
    "typedoc-plugin-extras": "^4.0.1",
    "typedoc-theme-hierarchy": "^6.0.0",
    "typescript-eslint": "^8.46.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
