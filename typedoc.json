{
    "$schema": "https://typedoc.org/schema.json",
    "name": "bitwise-flag",
    "entryPoints": [
        "./lib/core/index.ts",
        "./lib/flags/index.ts",
        "./lib/operators/index.ts"
    ],
    "tsconfig": "./tsconfig.typedoc.json",
    "theme": "hierarchy",
    "projectDocuments": [
        "./lib/**/*.md"
    ],
    "plugin": [
        "typedoc-theme-hierarchy",
        "typedoc-plugin-extras"
    ],
    "out": "docs",
    "gitRevision": "main",
    "footerLastModified": true,
    "includeVersion": true,
    "excludePrivate": true,
    "excludeExternals": true,
    "sourceLinkTemplate": "https://github.com/ThatsEmbarrassing/bitwise-flag/blob/{gitRevision}/{path}#L{line}"
}